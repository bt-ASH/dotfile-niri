      "max_stderr_chars": 4000
    },
    "memory": {
      "enabled": true,
      "evicted_context_enabled": true,
      "association_enabled": true,
      "auto_diary_enabled": true,
      "auto_fact_enabled": true,
      "auto_skill_enabled": false,
