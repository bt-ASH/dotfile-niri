      "max_download_mb": 4.0,
      "safe_search": true,
      "vision_screening_enabled": true,
      "auto_preview": true,
      "preview_count": 1,
      "timeout_seconds": 20
    },
    "deep_research": {
      "enabled": true,
      "output_dir": "/home/ash/Documents/Miyu/deep-thinking",
      "thinking_depth": "high",
      "max_review_revisions": 0,
