    },
    {
      "id": "anthropic",
      "display_name": "Anthropic",
      "base_url": "https://api.anthropic.com/v1",
      "protocol": "anthropic",
      "api_key": "$env:ANTHROPIC_API_KEY",
      "models": [
        "claude-sonnet-4-5"
      ],
      "default_model": "claude-sonnet-4-5"
    }
  ],
  "context": {
    "trim_at_ratio": 0.9,
    "trim_batch_ratio": 0.15,
    "on_overflow": "compact"
  },
  "tools": {
    "enabled": true,
    "max_rounds": 0,
    "loading_mode": "hybrid",
    "persist_loaded_tools": true
  },
  "skills": {
    "enabled": true,
    "allow_command_execution": true
  },
  "display": {
    "reasoning": "summary",
    "tool_calls": "summary",
    "readable_tool_names": true,
    "show_token_usage": false
  },
  "prompt": {
    "prompts_dir": "prompts",
    "identities_dir": "identities",
    "user_identity_file": "user-identity.md",
    "active_persona": "",
    "active_identity": ""
  },
  "plugins": {
    "weather": {
      "enabled": true
    },
    "web": {
      "enabled": true,
      "max_results": 2,
      "tavily_api_keys": [],
